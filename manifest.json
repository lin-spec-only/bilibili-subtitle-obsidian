{
  "manifest_version": 3,
  "name": "B站字幕提取器",
  "version": "0.4.8",
  "key": "",
  "description": "优先提取 B 站字幕，无字幕时可调用本机语音识别并导出为笔记。",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "minimum_chrome_version": "102",
  "permissions": [
    "clipboardWrite",
    "scripting",
    "storage",
    "tabs",
    "nativeMessaging"
  ],
  "host_permissions": [
    "https://bilibili.com/*",
    "https://*.bilibili.com/*",
    "https://b23.tv/*",
    "https://*.hdslb.com/*",
    "http://127.0.0.1:8766/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "提取 B 站字幕",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png"
    },
    "default_popup": "popup.html"
  }
}
